# ---------------------------------------------------------------------------
# Core (REQUIRED — the app will not start without these)
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/kandora-tournaments
# Public base URL of the app. The Discord OAuth redirect URI is
# APP_BASE_URL + /auth/discord/callback — register that exact URL in your
# Discord application. VITE_APP_BASE_URL (exposed to the browser) must match.
APP_BASE_URL=http://localhost:5173
VITE_APP_BASE_URL=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-string

# Optional SSO: share the login session across sub-domains. Set to a parent
# domain like ".example.com" ONLY if you run another Kandora app (e.g. the
# portal) under the same domain AND use the SAME JWT_SECRET on both. Leave
# unset for a normal host-only session.
# AUTH_COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Redis (BullMQ queues / scheduling). Use REDIS_URL in production.
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Discord OAuth (login) + Bot. Create an app at
# https://discord.com/developers/applications
# VITE_DISCORD_CLIENT_ID is exposed to the browser (login button).
# ---------------------------------------------------------------------------
VITE_DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# JSON array describing the Discord servers this instance manages, plus the
# role IDs that grant admin / editor permissions. Exactly one entry should set
# "isMain": true — its admin/editor roles govern app permissions.
# Example:
#   SERVERS_JSON=[{"id":"<guildId>","name":"My Club","isMain":true,"adminRoleId":"<roleId>","editorRoleId":"<roleId>","notificationChannelId":"<channelId>"}]
SERVERS_JSON=

# ---------------------------------------------------------------------------
# Game-platform connectors (optional). Set PLATFORM_CONNECTORS_DISABLED=true to
# force-disable all of them regardless of the values below.
# ---------------------------------------------------------------------------
PLATFORM_CONNECTORS_DISABLED=false
MAJSOUL_UID=
MAJSOUL_TOKEN=
MAJSOUL_FRIENDID=
RIICHICITY_EMAIL=
RIICHICITY_PASSWD=
RIICHICITY_GUID=
RIICHICITY_FRIENDID=

# ---------------------------------------------------------------------------
# Translation (optional — DeepL auto-translation)
# ---------------------------------------------------------------------------
DEEPL_API_KEY=

# ---------------------------------------------------------------------------
# Nanikiru quiz (optional — the bot's mahjong quiz pulls questions from a
# Google Sheet). Requires a Google service-account JSON with read access.
# ---------------------------------------------------------------------------
NANIKIRU_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---------------------------------------------------------------------------
# Workers — the league / scheduling / discord-sync BullMQ workers can run
# inline in the web process (true) or as separate processes
# (npm run worker:league / worker:scheduling). Defaults to inline in production.
# ---------------------------------------------------------------------------
ENABLE_INLINE_WORKER=false

# ---------------------------------------------------------------------------
# Uploads — directory for team / player pictures. In production point this at a
# mounted persistent volume.
# ---------------------------------------------------------------------------
# UPLOAD_DIR=.data/uploads

# Optional: port for the production server (react-router-serve; default 3000).
# PORT=3000

# Optional: mount the app under a sub-path (behind a shared reverse proxy).
# BASE_PATH=
