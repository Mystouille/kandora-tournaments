{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Tournaments (dev)",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${env:HOME}/.nvm/versions/node/v24.11.1/bin/node",
      "windows": {
        "runtimeExecutable": "node"
      },
      "program": "${workspaceFolder}/node_modules/@react-router/dev/bin.js",
      "args": ["dev", "--host", "--port", "5273"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome against Tournaments",
      "url": "http://localhost:5273/",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Debug Tournaments + Chrome",
      "configurations": [
        "Debug Tournaments (dev)",
        "Launch Chrome against Tournaments"
      ],
      "stopAll": true
    }
  ]
}
