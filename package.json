{
  "name": "kandora-tournaments",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "core:update": "git submodule update --init --remote app/db",
    "game:update": "git submodule update --init --remote app/game",
    "submodules:init": "git submodule update --init --recursive",
    "liqi:generate": "node app/db/majsoul/data/_gen-liqi.mjs",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "worker:league": "tsx app/services/leagueWorker.server.ts",
    "worker:scheduling": "tsx app/services/schedulingWorker.server.ts",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "lint": "eslint \"app/**/*.{ts,tsx,js,jsx}\" \"scripts/**/*.{ts,js}\" --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "deploy:commands": "tsx scripts/deploy-commands.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@nivo/bar": "^0.99.0",
