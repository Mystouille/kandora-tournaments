    "@react-router/dev": "7.10.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/busboy": "^1.5.4",
    "@types/crypto-js": "^4.2.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
