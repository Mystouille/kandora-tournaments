    "@react-router/serve": "7.10.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "antd": "^6.1.0",
    "bullmq": "^5.72.1",
    "busboy": "^1.6.0",
    "canvas": "^3.2.2",
    "country-flag-icons": "^1.6.15",
    "crypto-js": "^4.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "google-auth-library": "^9.15.1",
    "google-spreadsheet": "^5.2.0",
    "howler": "^2.2.4",
    "html-react-parser": "^5.2.17",
    "https-proxy-agent": "^8.0.0",
    "ioredis": "5.10.1",
    "isbot": "^5.1.31",
    "jose": "^6.1.3",
    "mongoose": "^9.0.1",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "pixi.js": "^8.18.1",
    "protobufjs": "^8.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "7.10.1",
    "riichi": "^1.2.0",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "syanten": "^1.6.0",
