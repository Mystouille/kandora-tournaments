{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "exclude": [
    "app/api/majsoul/**/*",
    "app/bot/**/*",
    "app/game/routes/lobby.tsx",
    "app/game/routes/match.tsx",
    "app/game/routes/spectate.tsx"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client", "vitest/globals"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"],
      "config": ["./config.ts"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
